{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "StrawHub",
  "colors": {
    "primary": "#2A8FE8",
    "light": "#52ADF2",
    "dark": "#1C6EC4"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
