            "pages": [
              "concepts/skills",
              "concepts/roles",
              "concepts/dependencies"
            ]
          },
          {
            "group": "CLI Reference",
            "icon": "terminal",
            "pages": ["cli/commands"]
          },
          {
            "group": "Publishing",
            "icon": "upload",
            "pages": [
              "publishing/guide",
              "publishing/frontmatter"
            ]
          }
        ]
